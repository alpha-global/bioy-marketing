---
pagination:
  data: globals.locales
  size: 1
  alias: locale
---

<section class="my-8">
  <p class="w-full max-w-screen-md px-4 mx-auto text-xl text-center text-black lg:text-3xl">
    {{ editions[locale].intro }}
  </p>
  <div class="flex flex-col items-center justify-center w-full p-4 mx-auto space-y-2 xs:flex-row xs:space-x-2 rtl:space-x-reverse xs:space-y-0 md:max-w-sm">
    {% if  editions[locale].classic %}
      <a class="w-full text-center whiteButton xs:w-1/3"
         href="/{{ locale }}/classic">{{ editions[locale].classic }}</a>
    {% endif %}
    {% if  editions[locale].youth %}
      <a class="w-full text-center whiteButton xs:w-1/3"
         href="/{{ locale }}/youth">{{ editions[locale].youth }}</a>
    {% endif %}
    {% if  editions[locale].express %}
      <a class="w-full text-center whiteButton xs:w-1/3"
         href="/{{ locale }}/express">{{ editions[locale].express }}</a>
    {% endif %}
  </div>
</section>
