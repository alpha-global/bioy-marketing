---
pagination:
  data: globals.locales
  size: 1
  alias: locale
---

<section id="todays-devotion"
         class="flex flex-col-reverse sm:grid sm:grid-cols-2">
  <div class="flex flex-col justify-center p-4 text-white bg-red md:py-8 lg:px-12">
    <div class="flex flex-col items-start self-end w-full lg:max-w-md">
      {% if today[locale].title %}<h2 class="mb-6 text-2xl font-bold lg:text-3xl">{{ today[locale].title }}</h2>{% endif %}
      {% for d in cms | devotionList(locale, variant) | reverse %}
        {% if loop.index <= 6 %}
          {% if loop.first %}
            <p class="mb-6">
              {% if today[locale].today %}
                <span class="inline-block p-2 pb-1 mb-1 text-sm uppercase bg-white rounded-sm text-red">{{ today[locale].today }}</span>
              {% endif %}
              <a href="{{ d.url }}" class="block underline">
                {% if today[locale].day %}{{ today[locale].day }}{% endif %}
                {% if  d.number %}{{ d.number }}:{% endif %}
                {% if d.bundle.title %}{{ d.bundle.title }}{% endif %}
              </a>
              <span class="text-xs">
                {% if d.bundle.wisdom.passage.reference %}{{ d.bundle.wisdom.passage.reference }}{% endif %}
                &middot;
                {% if d.bundle.newTestament.passage.reference %}{{ d.bundle.newTestament.passage.reference }}{% endif %}
                &middot;
                {% if  d.bundle.oldTestament.passage.reference %}{{ d.bundle.oldTestament.passage.reference }}{% endif %}
              </span>
            </p>
          {% else %}
            <p>
              <a {% if d.url %}href="{{ d.url }}"{% endif %} class="underline">
                {% if today[locale].day %}{{ today[locale].day }}{% endif %}
                {% if d.number %}{{ d.number }}:{% endif %}
                {% if d.budle.title %}{{ d.bundle.title }}{% endif %}
              </a>
            </p>
          {% endif %}
        {% endif %}
      {% endfor %}
      <p class="mt-4">
        {% if  today[locale].cta_tease %}{{ today[locale].cta_teaser }}{% endif %}
        {% if today[locale].cta %}<a class="underline" href="#start">{{ today[locale].cta }}</a>{% endif %}
      </p>
    </div>
  </div>
  <div>
    {% if today[locale].image %}
      {% blockImage today[locale].image, "reader", "(min-width: 640px) 50vw, 100vw",
      "object-cover h-full w-full" %}
    {% endif %}
  </div>
</section>
