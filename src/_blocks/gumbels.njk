---
pagination:
  data: globals.locales
  size: 1
  alias: locale
---

<section class="flex flex-col p-4 text-center text-black sm:text-left sm:px-0 sm:grid sm:grid-cols-2 sm:gap-4 lg:py-8">
  <div class="flex flex-col justify-end px-4 sm:self-end sm:col-span-2 lg:px-12 lg:col-span-1">
    <h2 class="self-end w-full text-2xl font-bold lg:text-3xl lg:max-w-md">{{ gumbels[locale].header }}</h2>
  </div>
  <main class="flex flex-col justify-start p-4 lg:order-1 lg:px-12">
    <div class="self-end w-full lg:max-w-md">
      <p class="mb-4 small">{{ gumbels[locale].intro }}</p>
      <blockquote class="my-4 standoutQuote">
        {{ gumbels[locale].quote }}
      </blockquote>
      {% if gumbels[locale].outro %}<p class="my-4">{{ gumbels[locale].outro }}</p>{% endif %}
      {% if gumbels[locale].cta %}
        <p>
          <a class="px-4 whiteButton" href="{{ gumbels[locale].cta.url }}">{{ gumbels[locale].cta.label }}</a>
        </p>
      {% endif %}
    </div>
  </main>
  <aside class="order-first mb-4 sm:order-none lg:row-span-2">
    <div class="w-2/3 mx-auto sm:mx-auto sm:w-full">
      {% if gumbels[locale].img %}
        {% blockImage gumbels[locale].img, "Nicky and Pippa Gumbel", "(min-width: 640px) 50vw, 66vw", "rounded-full sm:rounded-none u-NandPclipper" %}
        <svg height="0" width="0">
          <defs>
          <clipPath id="NandPclipper" clipPathUnits="objectBoundingBox">
          <path d="M1,0.29 V0.707 C0.917,0.88,0.735,1,0.524,1 C0.234,1,0,0.776,0,0.499 C0,0.24,0.205,0.026,0.469,0 H0.579 C0.766,0.019,0.925,0.132,1,0.29">
          </path>
          </clipPath>
          <clipPath id="NandPclipper-rtl" clipPathUnits="objectBoundingBox">
          <path d="M0,0.71 V0.293 C0.083,0.12,0.265,0,0.476,0 C0.766,0,1,0.224,1,0.501 C1,0.76,0.795,0.974,0.531,1 L0.421,1 C0.234,0.981,0.075,0.868,0,0.71">
          </path>
          </clipPath>
          </defs>
        </svg>
      {% endif %}
    </div>
  </aside>
</section>
